{
  "name": "jarvis-hologram-desktop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n metrics,vite -c blue,green \"npm run server\" \"vite\"",
    "server": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy-lively.ps1",
    "metrics": "powershell -ExecutionPolicy Bypass -File scripts/start-metrics.ps1",
    "metrics:install": "powershell -ExecutionPolicy Bypass -File scripts/install-metrics-startup.ps1",
    "metrics:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-metrics-startup.ps1"
  },
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "systeminformation": "^5.30.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "oxlint": "^1.71.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
