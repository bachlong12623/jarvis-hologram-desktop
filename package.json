{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -n metrics,vite -c blue,green \"npm run server\" \"vite\"",
    "server": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "wallpaper:build": "npm run build",
    "wallpaper:start": "cross-env WALLPAPER_MODE=1 electron .",
    "wallpaper": "npm run wallpaper:build && npm run wallpaper:start",
    "wallpaper:install": "powershell -ExecutionPolicy Bypass -File scripts/install-wallpaper.ps1",
    "wallpaper:stop": "powershell -ExecutionPolicy Bypass -Command \"Get-CimInstance Win32_Process -Filter \\\"Name='electron.exe'\\\" | Where-Object { $_.CommandLine -like '*UI*' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force }\"",
    "wallpaper:lively": "powershell -ExecutionPolicy Bypass -File scripts/setup-lively.ps1",
    "wallpaper:dev": "concurrently -n metrics,vite,electron -c blue,green,magenta \"npm run server\" \"vite\" \"cross-env DEV=1 WALLPAPER_MODE=1 electron .\""
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "koffi": "^3.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "systeminformation": "^5.30.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "oxlint": "^1.71.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
